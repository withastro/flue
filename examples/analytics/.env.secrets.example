# Copy to .env.secrets for local runs. Do not commit real secret values.

# Provider keys. Set the one matching ANALYTICS_MODEL or payload.model.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default model if payload.model is not provided.
ANALYTICS_MODEL=openai/gpt-4.1-mini

# Analytics resources.
DBT_MANIFEST_PATH=/Users/billgu/Workspace/dbt/target/manifest.json
# Used by the local manifest publish script before upload.
DBT_MANIFEST_QUERY_SCHEMA=dbt_prod
DBT_MANIFEST_GCS_URI=gs://evenup-internal-tools-dev-dbt-explorer-api/dbt-explorer/manifest/manifest.json
METABASE_API_KEY=

# EvenUp internal-tools persistence defaults. These are non-secret and match
# dbt-explorer-api local dev; GKE injects prod env vars from the chart.
GCP_PROJECT=evenup-internal-tools
FIRESTORE_DATABASE=dev-dbt-explorer-api
GCS_BUCKET=evenup-internal-tools-dev-dbt-explorer-api

# Optional script overrides.
BQ_EXPLORE_SCRIPT=/Users/billgu/Workspace/evenup-internal-tools/apps/dbt-explorer-api/claude-copy/scripts/bq_explore/bq_explore.py
METABASE_CLI_SCRIPT=/Users/billgu/Workspace/evenup-internal-tools/apps/dbt-explorer-api/claude-copy/scripts/metabase/metabase-cli.py
