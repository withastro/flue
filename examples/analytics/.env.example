# Copy to .env for environment-specific, non-secret config.
# Keep provider keys and API tokens in .env.secrets.

# Local dev: point directly at the normalized dbt_prod manifest produced by
# pnpm manifest:publish / pnpm manifest:preprocess.
DBT_MANIFEST_PATH=/Users/billgu/Workspace/dbt/target/manifest.dbt_prod.json

# GKE/prod: set DBT_MANIFEST_PATH to the local container path where startup
# downloads this GCS object.
DBT_MANIFEST_GCS_URI=gs://evenup-internal-tools-dev-dbt-explorer-api/dbt-explorer/manifest/manifest.json
DBT_MANIFEST_QUERY_SCHEMA=dbt_prod

# Default models.
WAITER_MODEL=anthropic/claude-opus-4-7
EXPLORER_MODEL=openai/gpt-5.4-nano
ANALYTICS_MODEL=openai/gpt-5.4

# EvenUp internal-tools persistence defaults. These match dbt-explorer-api
# local dev; GKE injects prod values from the app namespace.
GCP_PROJECT=evenup-internal-tools
FIRESTORE_DATABASE=dev-dbt-explorer-api
GCS_BUCKET=evenup-internal-tools-dev-dbt-explorer-api

# Optional script overrides.
BQ_EXPLORE_SCRIPT=resources/scripts/bq_explore/bq_explore.py
METABASE_CLI_SCRIPT=resources/scripts/metabase/metabase-cli.py
