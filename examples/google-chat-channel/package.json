{
	"name": "google-chat-channel-example",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "flue build --target node",
		"check:types": "tsc --noEmit",
		"test": "pnpm run test:node && pnpm run test:workerd",
		"test:node": "vitest run test/client.test.ts test/conversation.test.ts",
		"test:workerd": "vitest run --config vitest.workerd.config.ts"
	},
	"dependencies": {
		"@flue/google-chat": "workspace:*",
		"@flue/runtime": "workspace:*",
		"jose": "*",
		"valibot": "^1.0.0"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.16.15",
		"@flue/cli": "workspace:*",
		"agents": "^0.14.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	}
}
