{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": [
		"ANTHROPIC_API_KEY",
		"GITHUB_TOKEN",
		"GITHUB_WEBHOOK_SECRET",
		"ASTRO_REPO",
		"ASTRO_BRANCH"
	],
	"tasks": {
		"dev": {
			"persistent": true,
			"cache": false
		},
		"build": {},
		"//#check:lint": {},
		"check:types": {
			"dependsOn": ["build", "^build", "^check:types"],
			"outputLogs": "errors-only"
		},
		"test": {
			// Tests import package source directly via vitest's esbuild
			// transform — no `dependsOn: ["build"]` needed. Cross-package
			// type imports still resolve through `^build` so e.g. the
			// runtime test that imports the CLI's wrangler-merge helpers
			// works on a clean checkout.
			"dependsOn": ["^build"],
			"outputLogs": "new-only"
		},
		"//#format:lint": {},
		"//#format:style": {
			"dependsOn": ["format:lint"]
		}
	}
}
