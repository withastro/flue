{
	"name": "apps-docs",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"astro": "astro",
		"build": "rm -rf ./dist && astro build && mv ./dist/docs/_redirects ./dist/_redirects && pagefind --site ./dist/docs",
		"check:types": "astro check",
		"deploy": "pnpm run build && wrangler deploy",
		"dev": "astro dev",
		"preview": "astro preview"
	},
	"dependencies": {
		"@astrojs/mdx": "^5.0.6",
		"@astrojs/starlight": "^0.39.2",
		"@paper-design/shaders": "0.0.76",
		"@tailwindcss/vite": "^4.2.0",
		"astro": "^6.3.7",
		"minisearch": "^7.2.0",
		"tailwindcss": "^4.2.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"pagefind": "^1.5.2",
		"typescript": "^6.0.3",
		"vite": "catalog:",
		"wrangler": "^4.97.0"
	}
}
