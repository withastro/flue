---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { channels, databases, deploy, sandboxes, tooling } from '../../../../ecosystem-catalog';
---

<DocsLayout
	title="Ecosystem"
	description="Browse deployment guides, channels, databases, sandbox adapters, and developer tooling for Flue applications."
	currentSlug="ecosystem"
	headings={[]}
	showTableOfContents={false}
	variant="directory"
>
	<div class="ecosystem-directory">
		<header class="mb-4">
			<h1 class="m-0 text-5xl font-bold leading-[1.08] tracking-[-0.05em] text-gray-950 max-docs-desktop:text-[2.375rem]">Ecosystem</h1>
			<p class="mt-4 max-w-175 text-base leading-7 text-gray-600">Deploy Flue applications and extend them with channels, databases, sandbox environments, and the tools your agents already use.</p>
		</header>

		<label class="relative mb-14 block" for="ecosystem-search">
			<span class="sr-only">Search ecosystem</span>
			<svg class="pointer-events-none absolute top-1/2 left-3.5 size-4.5 -translate-y-1/2 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
				<circle cx="11" cy="11" r="7"></circle>
				<path d="m20 20-3.8-3.8"></path>
			</svg>
			<input id="ecosystem-search" class="h-11 w-full rounded-lg border border-transparent bg-docs-code pr-3.5 pl-10.5 text-base leading-none text-gray-950 outline-none transition-colors duration-150 placeholder:text-gray-500 hover:border-gray-300 focus:border-gray-500 focus:bg-white" type="search" placeholder="Search ecosystem..." autocomplete="off" />
		</label>

		<section class="ecosystem-section mb-14" data-ecosystem-section>
			<h2 id="channels" class="mb-6 scroll-mt-20 text-3xl font-semibold tracking-[-0.03em] text-gray-950">Channels</h2>
			<ul class="ecosystem-grid" role="list">
				{channels.map((item) => (
					<li data-ecosystem-item data-search={`${item.name} ${item.keywords ?? ''}`.toLowerCase()}>
						<a class="ecosystem-item group" href={item.href} aria-label={item.name}>
							<span class="ecosystem-icon" style={`--ecosystem-icon-bg: ${item.background}`}>
								{item.icon ? (
									<img class:list={['ecosystem-logo', item.iconClass]} src={item.icon} alt="" loading="lazy" />
								) : item.mark === 'messenger' ? (
									<svg class="ecosystem-brand-symbol" viewBox="0 0 800 800" aria-hidden="true">
										<defs><radialGradient id="messenger-gradient" cx="101.9" cy="809" r="1.1" gradientTransform="matrix(800 0 0 -800 -81386 648000)" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#09f" /><stop offset=".6" stop-color="#a033ff" /><stop offset=".9" stop-color="#ff5280" /><stop offset="1" stop-color="#ff7061" /></radialGradient></defs>
										<path fill="url(#messenger-gradient)" d="M400 0C174.7 0 0 165.1 0 388c0 116.6 47.8 217.4 125.6 287 6.5 5.8 10.5 14 10.7 22.8l2.2 71.2a32 32 0 0 0 44.9 28.3l79.4-35c6.7-3 14.3-3.5 21.4-1.6 36.5 10 75.3 15.4 115.8 15.4 225.3 0 400-165.1 400-388S625.3 0 400 0z" />
										<path fill="#fff" d="m159.8 501.5 117.5-186.4a60 60 0 0 1 86.8-16l93.5 70.1a24 24 0 0 0 28.9-.1l126.2-95.8c16.8-12.8 38.8 7.4 27.6 25.3L522.7 484.9a60 60 0 0 1-86.8 16l-93.5-70.1a24 24 0 0 0-28.9.1l-126.2 95.8c-16.8 12.8-38.8-7.3-27.5-25.2z" />
									</svg>
								) : item.mark === 'intercom' ? (
									<svg class="ecosystem-brand-symbol text-white" viewBox="0 0 64 64" aria-hidden="true">
										<path d="M15 18v22M23.5 14v29M32 12v32M40.5 14v29M49 18v22" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round" />
										<path d="M13 47c11 7 27 7 38 0" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
									</svg>
								) : item.mark === 'zendesk' ? (
									<svg class="ecosystem-brand-symbol text-black" viewBox="0 0 14 14" aria-hidden="true">
										<path fill="currentColor" d="m6.5425 11.5475-5.5425 0 5.5425-6.6915v6.6915zm6.4575 0-5.5425 0c0-1.5315 1.2395-2.7715 2.7715-2.7715 1.5315 0 2.771 1.241 2.771 2.7715zm-5.5425-2.402v-6.693H13l-5.5425 6.693zM6.5425 2.4525c0 1.5305-1.2405 2.772-2.7715 2.772C2.241 5.2245 1 3.984 1 2.4535l5.5425-.001z" />
									</svg>
								) : (
									<span class="ecosystem-mark">{item.mark}</span>
								)}
							</span>
							<span class="ecosystem-name">{item.name}</span>
						</a>
					</li>
				))}
			</ul>
		</section>

		<section class="ecosystem-section mb-14" data-ecosystem-section>
			<h2 id="sandboxes" class="mb-6 scroll-mt-20 text-3xl font-semibold tracking-[-0.03em] text-gray-950">Sandboxes</h2>
			<ul class="ecosystem-grid" role="list">
				{sandboxes.map((item) => (
					<li data-ecosystem-item data-search={`${item.name} ${item.keywords ?? ''}`.toLowerCase()}>
						<a class="ecosystem-item group" href={item.href} aria-label={item.name}>
							<span class="ecosystem-icon" style={`--ecosystem-icon-bg: ${item.background}`}>
								{item.icon ? (
									<img class:list={['ecosystem-logo', item.iconClass]} src={item.icon} alt="" loading="lazy" />
								) : (
									<span class="ecosystem-default-grid" aria-hidden="true" />
								)}
							</span>
							<span class="ecosystem-name">{item.name}</span>
						</a>
					</li>
				))}
			</ul>
		</section>

		<section class="ecosystem-section mb-14" data-ecosystem-section>
			<h2 id="deploy" class="mb-6 scroll-mt-20 text-3xl font-semibold tracking-[-0.03em] text-gray-950">Deploy</h2>
			<ul class="ecosystem-grid" role="list">
				{deploy.map((item) => (
					<li data-ecosystem-item data-search={`${item.name} ${item.keywords ?? ''}`.toLowerCase()}>
						<a class="ecosystem-item group" href={item.href} aria-label={item.name}>
							<span class="ecosystem-icon" style={`--ecosystem-icon-bg: ${item.background}`}>
								{item.icon ? (
									<img class:list={['ecosystem-logo', item.iconClass]} src={item.icon} alt="" loading="lazy" />
								) : (
									<span class="ecosystem-mark">{item.mark}</span>
								)}
							</span>
							<span class="ecosystem-name">{item.name}</span>
						</a>
					</li>
				))}
			</ul>
		</section>

		<section class="ecosystem-section mb-14" data-ecosystem-section>
			<h2 id="databases" class="mb-6 scroll-mt-20 text-3xl font-semibold tracking-[-0.03em] text-gray-950">Databases</h2>
			<ul class="ecosystem-grid" role="list">
				{databases.map((item) => (
					<li data-ecosystem-item data-search={`${item.name} ${item.keywords ?? ''}`.toLowerCase()}>
						<a class="ecosystem-item group" href={item.href} aria-label={item.name}>
							<span class="ecosystem-icon" style={`--ecosystem-icon-bg: ${item.background}`}>
								{item.icon ? (
									<img class:list={['ecosystem-logo', item.iconClass]} src={item.icon} alt="" loading="lazy" />
								) : item.mark === 'sqlite' ? (
									<svg class="ecosystem-database-logo" viewBox="0 0 256 256" aria-hidden="true">
										<defs><linearGradient id="sqlite-gradient" x1="0" y1="0" x2="0" y2="1"><stop stop-color="#97d9f6" /><stop offset=".92" stop-color="#0f80cc" /><stop offset="1" stop-color="#0f80cc" /></linearGradient></defs>
										<path fill="#0f80cc" d="M50.5 40.3h131.8c8.3 0 15 6.7 15 15v132c0 8.3-6.7 15-15 15H50.5c-8.3 0-15-6.7-15-15v-132c0-8.3 6.7-15 15-15Z" />
										<path fill="url(#sqlite-gradient)" d="M50.5 44.7h127.5c-18.5 21.7-34.6 55.8-40 81.8-27.2-.4-64.9 9.1-98.1 19.2V55.3c0-5.9 4.7-10.6 10.6-10.6Z" />
										<path fill="#003b57" d="M220.9 36.2c-17.4-15.5-40.7 12.8-54.4 37.9-12.8 23.3-23.2 51.8-26.2 72.3 7.7 15.1 10 35.8 9.7 50.7.8 13 3.4 24.7 7.8 31.5l1.3-.7c-4.1-13.1-4.7-31.1-1.5-51.3 4.8-30.3 18.2-67.4 36.4-94.5-16.9 28-27.1 54.4-33.8 77.5 8.3-15.7 23.9-20 23.9-20s10.9-12.4 20.4-26.2c-9.8 1.8-17.5 4-24.2 6.6 19.7-12.7 58.5-67.8 40.6-83.8Z" />
									</svg>
								) : item.mark === 'turso' ? (
									<svg class="ecosystem-database-logo ecosystem-turso-logo" viewBox="0 0 241 240" fill="none" aria-hidden="true">
										<path d="M120.055 205C117.865 205 101.855 192.2 98.7549 188.55C96.3149 192.28 92.3149 196.51 92.3149 196.51C81.2649 190.94 67.1449 176.45 64.4849 171.38C61.8649 166.38 52.3549 108.8 52.0949 92.08C51.7549 82.67 57.9449 63.59 120.055 63.59C182.165 63.59 188.345 82.67 188.015 92.08C187.765 108.8 178.255 166.38 175.625 171.38C172.965 176.45 158.845 190.94 147.795 196.51C147.795 196.51 143.795 192.28 141.355 188.55C138.255 192.2 122.245 205 120.055 205Z" fill="#1EBCA1" />
										<path d="M120.055 167.92C99.3249 167.92 86.0949 156.97 86.0949 156.97L88.0049 130.3L66.2549 128.36L62.3449 96.81H177.775L173.865 128.36L152.115 130.3L154.025 156.97C154.025 156.97 140.795 167.92 120.065 167.92H120.055Z" fill="#183134" />
										<path d="M141.535 110.79L220.055 83.61C215.385 55.67 190.895 35 190.895 35V65.78L176.355 69.53L167.245 58.56L159.445 73.9L120.065 84.06L80.6849 73.9L72.8849 58.56L63.7749 69.53L49.2349 65.78V35C49.2349 35 24.7249 55.67 20.0549 83.61L98.5749 110.79L95.7749 148.18C102.475 149.88 109.525 151.57 120.055 151.57C130.585 151.57 137.625 149.88 144.325 148.18L141.525 110.79H141.535Z" fill="#4FF8D2" />
									</svg>
								) : item.mark === 'valkey' ? (
									<svg class="ecosystem-database-logo text-white" viewBox="0 0 512 512" aria-hidden="true">
										<path fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" d="m126.1 431.2-91.7-57.4V128.6L258.7 0l218.9 128.8v258L255.2 512 178 463.7V346.2L136.2 320V187l121.2-69.5 118.4 69.7v139.4L282 379.4v-56.1c28.1-10.8 48.3-38.6 48.3-71.5 0-42.3-33.5-76.3-74.3-76.3s-74.3 34-74.3 76.3c0 32.8 20.2 60.6 48.3 71.5v106.3l26.8 16.8 164.4-92.6V161.1L258.3 65.3l-167.5 96v181.3l35.3 22.1zM256 216.7c18.5 0 33.1 15.9 33.1 35.1 0 19.1-14.6 35.1-33.1 35.1s-33.1-15.9-33.1-35.1 14.6-35.1 33.1-35.1" />
									</svg>
								) : (
									<span class="ecosystem-default-grid" aria-hidden="true" />
								)}
							</span>
							<span class="ecosystem-name">{item.name}</span>
						</a>
					</li>
				))}
			</ul>
		</section>

		<section class="ecosystem-section mb-14" data-ecosystem-section>
			<h2 id="tooling" class="mb-6 scroll-mt-20 text-3xl font-semibold tracking-[-0.03em] text-gray-950">Tooling</h2>
			<ul class="ecosystem-grid" role="list">
				{tooling.map((item) => (
					<li data-ecosystem-item data-search={`${item.name} ${item.keywords ?? ''}`.toLowerCase()}>
						<a class="ecosystem-item group" href={item.href} aria-label={item.name}>
							<span class="ecosystem-icon" style={`--ecosystem-icon-bg: ${item.background}`}>
								{item.icon ? (
									<img class:list={['ecosystem-logo', item.iconClass]} src={item.icon} alt="" loading="lazy" />
								) : (
									<span class="ecosystem-default-grid" aria-hidden="true" />
								)}
							</span>
							<span class="ecosystem-name">{item.name}</span>
						</a>
					</li>
				))}
			</ul>
		</section>


		<p class="ecosystem-empty hidden rounded-2xl border border-dashed border-gray-300 py-12 text-center text-gray-500" data-ecosystem-empty>No ecosystem integrations match that search.</p>
	</div>
</DocsLayout>

<script>
	const search = document.querySelector<HTMLInputElement>('#ecosystem-search');
	const items = [...document.querySelectorAll<HTMLElement>('[data-ecosystem-item]')];
	const sections = [...document.querySelectorAll<HTMLElement>('[data-ecosystem-section]')];
	const grids = [...document.querySelectorAll<HTMLElement>('.ecosystem-grid')];
	const empty = document.querySelector<HTMLElement>('[data-ecosystem-empty]');

	search?.addEventListener('input', () => {
		const query = search.value.trim().toLowerCase();
		let visibleCount = 0;

		for (const grid of grids) grid.classList.toggle('is-filtering', query.length > 0);

		for (const item of items) {
			const visible = (item.dataset.search ?? '').includes(query);
			item.hidden = !visible;
			if (visible) visibleCount += 1;
		}

		for (const section of sections) {
			section.hidden = !section.querySelector('[data-ecosystem-item]:not([hidden])');
		}

		if (empty) empty.hidden = visibleCount !== 0;
	});
</script>

<style>
	.ecosystem-grid {
		--ecosystem-tile-size: clamp(5.25rem, 6.4vw, 5.875rem);
		display: grid;
		/* auto-fill (not auto-fit) keeps a fixed column count based on the
		   container width, so a 3-item section lines up on the exact same
		   columns as a 20-item section. minmax(tile, 1fr) grows the columns to
		   fill leftover space on a full row, and justify-items: center keeps the
		   fixed-size tiles centered in their tracks for even spacing. */
		grid-template-columns: repeat(auto-fill, minmax(var(--ecosystem-tile-size), 1fr));
		justify-items: center;
		gap: clamp(1rem, 1.6vw, 1.35rem) clamp(0.75rem, 1.2vw, 1rem);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.ecosystem-item {
		display: flex;
		width: var(--ecosystem-tile-size);
		min-width: 0;
		flex-direction: column;
		align-items: center;
		gap: 0.65rem;
		text-align: center;
	}

	.ecosystem-icon {
		display: grid;
		width: var(--ecosystem-tile-size);
		aspect-ratio: 1;
		place-items: center;
		overflow: hidden;
		border: 1px solid rgb(17 24 39 / 0.09);
		border-radius: 1.45rem;
		background: var(--ecosystem-icon-bg);
		box-shadow:
			inset 0 1px 0 rgb(255 255 255 / 0.24),
			0 1px 2px rgb(17 24 39 / 0.12),
			0 4px 10px rgb(17 24 39 / 0.1);
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.ecosystem-item:hover .ecosystem-icon,
	.ecosystem-item:focus-visible .ecosystem-icon {
		border-color: rgb(37 99 235 / 0.65);
		box-shadow:
			inset 0 1px 0 rgb(255 255 255 / 0.24),
			0 1px 2px rgb(17 24 39 / 0.14),
			0 5px 12px rgb(17 24 39 / 0.12);
	}

	.ecosystem-logo {
		width: 61%;
		height: 61%;
		object-fit: contain;
	}

	.ecosystem-logo.invert {
		filter: invert(1);
	}

	.ecosystem-logo.ecosystem-logo-large {
		width: 82%;
		height: 82%;
	}

	.ecosystem-logo.ecosystem-logo-small {
		width: 48%;
		height: 48%;
	}

	.ecosystem-logo.ecosystem-logo-tooling {
		width: 52%;
		height: 52%;
	}

	.ecosystem-logo.monochrome-white {
		filter: brightness(0) invert(1);
	}

	.ecosystem-logo.ecosystem-logo-mongodb {
		width: 42%;
		height: 58%;
		object-position: center;
	}

	.ecosystem-database-logo {
		width: 66%;
		height: 66%;
	}

	.ecosystem-turso-logo {
		width: 72%;
		height: 72%;
	}

	.ecosystem-brand-symbol {
		width: 58%;
		height: 58%;
	}

	/* Default placeholder for ecosystem items without a logo: a 30deg white
	   drafting grid over a light blue gradient, brighter at the top as if lit
	   from above (the homepage blue accent). Clipped to the rounded tile. */
	.ecosystem-default-grid {
		width: 100%;
		height: 100%;
		border-radius: inherit;
		background:
			repeating-linear-gradient(30deg, rgb(255 255 255 / 0.26) 0, rgb(255 255 255 / 0.26) 1px, transparent 1px, transparent 13px),
			repeating-linear-gradient(120deg, rgb(255 255 255 / 0.26) 0, rgb(255 255 255 / 0.26) 1px, transparent 1px, transparent 13px),
			linear-gradient(180deg, #5a98f6 0%, #3173ea 100%);
	}

	.ecosystem-mark {
		color: white;
		font-size: 2.1rem;
		font-weight: 700;
		letter-spacing: -0.06em;
	}

	.ecosystem-name {
		max-width: none;
		color: #25262b;
		font-size: 0.74rem;
		font-weight: 500;
		line-height: 1.2;
		white-space: nowrap;
	}

	.ecosystem-item:hover .ecosystem-name {
		color: #1d4ed8;
	}

	[hidden] {
		display: none !important;
	}

	@media (max-width: 760px) {
		.ecosystem-grid {
			--ecosystem-tile-size: clamp(5rem, 22vw, 5.5rem);
			gap: 1.25rem 0.75rem;
		}

		.ecosystem-icon {
			border-radius: 1.25rem;
		}
	}
</style>
