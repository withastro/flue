---
import "../styles/global.css";
import { Code } from "astro:components";
import { createHighlighter } from "shiki";
import { HERO, SUPPORT_AGENT, ISSUE_TRIAGE, CODING_AGENT, DATA_AGENT } from "../code-snippets";

const replaces: Record<string, string[]> = {
  support: ['Intercom AI', 'Zendesk AI', 'Ada'],
  triage: ['Dosu', 'Sweep', 'Ellipsis'],
  coding: ['Devin', 'Copilot Workspace', 'Cursor Background Agents'],
  data: ['Tableau AI', 'Power BI Copilot', 'DataGPT'],
};

const tabs = [
  { id: 'support', label: 'AI support agent', badgeLabel: 'Support Agent', code: SUPPORT_AGENT, lines: SUPPORT_AGENT.split('\n').length - 1 },
  { id: 'triage', label: 'AI issue triage', badgeLabel: 'Issue Triage', code: ISSUE_TRIAGE, lines: ISSUE_TRIAGE.split('\n').length - 1 },
  { id: 'coding', label: 'AI coding agent', badgeLabel: 'Coding Agent', code: CODING_AGENT, lines: CODING_AGENT.split('\n').length - 1 },
  { id: 'data', label: 'AI data assistant', badgeLabel: 'Data Agent', code: DATA_AGENT, lines: DATA_AGENT.split('\n').length - 1 },
];

const highlighter = await createHighlighter({
  themes: ['github-light'],
  langs: ['typescript'],
});

const highlighted = tabs.map((tab) => ({
  ...tab,
  html: highlighter.codeToHtml(tab.code, { lang: 'typescript', theme: 'github-light' }),
}));

highlighter.dispose();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Flue — The Sandbox Agent Framework</title>
    <meta name="description" content="The TypeScript agent harness for building powerful AI agents that can execute complex workflows. Support agents, coding agents, data analysis, and more. Deploy anywhere." />
    <meta name="theme-color" content="#ffffff" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Flue — The Sandbox Agent Framework" />
    <meta property="og:description" content="The TypeScript agent harness for building powerful AI agents that can execute complex workflows. Support agents, coding agents, data analysis, and more." />
    <meta property="og:url" content="https://flueframework.com" />
    <meta property="og:image" content="https://flueframework.com/og.jpg" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Flue — The Sandbox Agent Framework" />
    <meta name="twitter:description" content="The TypeScript agent harness for building powerful AI agents that can execute complex workflows. Support agents, coding agents, data analysis, and more." />
    <meta name="twitter:image" content="https://flueframework.com/og.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-gray-950 font-[system-ui,sans-serif] antialiased">

    <!-- NAV -->
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-sm border-b border-gray-200">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="flex items-baseline gap-2">
          <span class="text-2xl font-extrabold tracking-tight text-gray-950 leading-8">Flue</span><span id="nav-tagline" class="overflow-hidden h-8 leading-8"><span class="inline-block text-base sm:text-lg text-gray-500 translate-y-full opacity-0 transition-all duration-300 ease-out">The sandbox agent framework.</span></span>
        </a>
        <div class="hidden sm:flex items-center gap-6">
          <a href="https://github.com/withastro/flue" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-950 transition-colors" aria-label="GitHub">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </nav>

    <!-- HERO (white bg) -->
    <section class="bg-white">
      <div class="max-w-6xl mx-auto px-6 pt-20 pb-16 lg:pt-28 lg:pb-20">
          <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1]">
            The Sandbox Agent Framework
          </h1>
          <p class="mt-6  max-w-2xl text-lg lg:text-2xl text-gray-500 text-balance">
            Flue is the TypeScript agent harness for building powerful AI agents for complex tasks and multi-step workflows.
          </p>
          <div class="mt-8 flex items-center gap-4">
            <a href="https://github.com/withastro/flue" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-2.5 bg-gray-950 hover:bg-gray-800 rounded-full px-5 py-3 text-sm font-medium text-white transition-colors">
              Get Started
              <svg class="w-4 h-4 text-gray-400 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
        </div>

        <!-- Full-width code snippet -->
        <div class="mt-14">
          <div class="hero-code border border-gray-300 rounded-sm overflow-hidden [&_pre]:p-6 [&_pre]:text-sm [&_pre]:leading-relaxed [&_pre]:overflow-x-auto [&_pre]:m-0 [&_pre]:rounded-none">
            <Code code={HERO} lang="typescript" theme="github-light" />
          </div>
        </div>
      </div>
    </section>

    <!-- Everything below hero: cool off-white bg -->
    <div class="bg-gray-200 h-px"></div>
    <div class="bg-[#f8f9fb]">

    <!-- SECTION 1: What is a Sandbox Agent? -->
    <section>
      <div class="max-w-6xl mx-auto px-6 py-24 pt-36">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
          <div class="lg:col-span-7">
            <h2 class="font-heading text-3xl sm:text-4xl font-bold tracking-tight leading-[1.1] text-balance">
               What is a Sandbox Agent?
            </h2>
            <p class="mt-4 text-lg text-gray-500 leading-relaxed">
              A <a href="https://developers.openai.com/api/docs/guides/agents/sandboxes" target="_blank" rel="noopener noreferrer" class="text-gray-950 underline decoration-gray-300 underline-offset-2 hover:decoration-gray-950 transition-colors">Sandbox Agent</a> pairs an agent harness with a workspace. Your agent can edit files, write and execute code, run terminal commands, search codebases, and drive itself autonomously to solve any given task.
            </p>
            <p class="mt-6 text-lg text-gray-500 leading-relaxed">
              You don't always need a full container. Flue gives you a spectrum &mdash; from <strong class="text-gray-700 font-medium">virtual sandboxes</strong> that are fast, cheap, and infinitely scalable, to <strong class="text-gray-700 font-medium">full container environments</strong> with git, Node.js, a browser, and everything else a real coding agent needs.
            </p>
          </div>

          <!-- Diagram: Agent → Sandbox -->
          <div class="lg:col-span-5 flex justify-center">
            <div class="w-full max-w-sm flex flex-col items-center gap-0">
              <!-- Agent card -->
              <div class="relative z-10 w-full bg-white border border-gray-300 rounded-sm p-4">
                <div class="flex items-center gap-2.5 text-[13px] font-mono text-gray-600 tracking-wider uppercase">
                  <svg class="w-4 h-4 text-gray-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" /></svg>
                  flue run agents/support.ts
                </div>
              </div>

              <!-- Animated line (behind cards) -->
              <div class="-my-1 z-0">
                <div class="w-[3px] h-10 animated-dash"></div>
              </div>

              <!-- Sandbox card -->
              <div class="relative z-10 w-full bg-white border border-blue-300 rounded-sm p-4">
                <div class="flex items-center gap-2 text-[11px] font-semibold text-gray-400 tracking-wider uppercase">
                  <svg class="w-3.5 h-3.5 text-blue-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                  My Support Agent
                </div>
                <div class="mt-2.5 space-y-1 text-[13px]">
                  <div class="flex items-center justify-between">
                    <span class="text-gray-400">Sandbox</span>
                    <span class="font-[JetBrains_Mono,monospace] text-gray-700">/workspace/project</span>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-gray-400">Context</span>
                    <span class="font-[JetBrains_Mono,monospace] text-gray-700">AGENTS.md</span>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-gray-400">Skills</span>
                    <span class="font-[JetBrains_Mono,monospace] text-gray-700">triage, support, fix</span>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-gray-400">Role</span>
                    <span class="font-[JetBrains_Mono,monospace] text-gray-700">support-expert</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 2: Build Your Own -->
    <section class="">
      <div class="max-w-6xl mx-auto px-6 py-24">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
          <div class="lg:col-span-5 lg:self-start">
            <div class="min-h-[calc(3*1.25*1.875rem)] sm:min-h-0 flex items-end">
              <h2 class="font-heading text-3xl sm:text-4xl font-bold tracking-tight leading-[1.1]">
                Build your own <span id="build-label" class="text-blue-700">{highlighted[0].label}</span> in <span id="build-lines">{highlighted[0].lines}</span> lines of TypeScript.
              </h2>
            </div>
            <p class="mt-6 text-lg text-gray-500 leading-relaxed">
               Off-the-shelf AI tools are one-size-fits-all. Flue gives you the building blocks to build something better &mdash; customized to your product, your data, and your exact requirements.
             </p>
             <p class="mt-4 text-lg text-gray-500 leading-relaxed">
                You own everything. Bring your own API keys, run on your own infrastructure, and customize every line of code. No vendor lock-in or black boxes.
             </p>
            <div class="mt-8">
              <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Replaces</p>
              <div id="build-replaces" class="mt-3 -ml-1 flex flex-wrap items-center gap-2">
                {replaces[tabs[0].id].map((name) => (
                  <span class="replaces-badge inline-flex items-center rounded-full bg-gray-200/70 px-3 py-1 text-xs font-medium text-gray-600 transition-all duration-300">{name}</span>
                ))}
              </div>
            </div>
          </div>

          <div class="lg:col-span-7 min-w-0">
            <div class="bg-white border border-gray-300 rounded-sm overflow-hidden">
              <div class="flex gap-1 p-2 [&>button]:flex-1" id="build-badges" data-tabdata={JSON.stringify(Object.fromEntries(highlighted.map(t => [t.id, { label: t.label, lines: t.lines, replaces: replaces[t.id] }])))}>
                {highlighted.map((tab, i) => (
                  <button
                    data-build={tab.id}
                    class:list={[
                      'build-badge px-3 py-2 text-sm font-medium transition-colors rounded-sm cursor-pointer',
                      i === 0
                        ? 'text-gray-950 bg-gray-200/70'
                        : 'text-gray-500 hover:text-gray-700',
                    ]}
                  >
                    {tab.badgeLabel}
                  </button>
                ))}
              </div>
              {highlighted.map((tab, i) => (
                <div
                  id={`build-code-${tab.id}`}
                  class:list={['build-code-panel [&_pre]:p-6 [&_pre]:pt-2 [&_pre]:text-sm [&_pre]:leading-loose [&_pre]:overflow-x-auto [&_pre]:min-h-[360px] [&_pre]:m-0 [&_pre]:rounded-none', i !== 0 && 'hidden']}
                  set:html={tab.html}
                />
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- DEPLOY GRID -->
    <section>
      <div class="max-w-6xl mx-auto px-6 py-24">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider text-center">Deploy Anywhere</p>
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border border-gray-300 rounded-sm">
          <!-- GitHub Actions -->
          <a href="https://github.com/withastro/flue/blob/main/docs/deploy-github-actions.md" target="_blank" rel="noopener noreferrer" class="runner-cell group relative overflow-hidden flex flex-col items-center justify-center gap-4 py-10 px-6 hover:bg-white transition-colors duration-300">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: radial-gradient(circle at 80% 80%, rgba(24,23,23,0.1) 0%, transparent 60%);"></div>
            <svg class="relative w-10 h-10 grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300" viewBox="0 0 24 24" fill="#181717"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            <span class="relative inline-flex items-center gap-1.5 rounded-full border border-gray-300 bg-white px-4 py-1.5 text-xs font-medium text-gray-600 group-hover:text-gray-950 group-hover:border-gray-400 transition-colors text-center shadow-sm">GitHub Actions</span>
          </a>
          <!-- GitLab CI/CD -->
          <a href="https://github.com/withastro/flue/blob/main/docs/deploy-gitlab-ci.md" target="_blank" rel="noopener noreferrer" class="runner-cell group relative overflow-hidden flex flex-col items-center justify-center gap-4 py-10 px-6 border-y sm:border-y-0 sm:border-x border-gray-300 hover:bg-white transition-colors duration-300">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: radial-gradient(circle at 80% 80%, rgba(226,67,41,0.1) 0%, transparent 60%), radial-gradient(circle at 20% 20%, rgba(252,163,38,0.1) 0%, transparent 60%);"></div>
            <svg class="relative w-10 h-10 grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300" viewBox="0 0 1000 963.197"><defs><style>.gl1{fill:#e24329}.gl2{fill:#fc6d26}.gl3{fill:#fca326}</style></defs><g transform="matrix(5.2068817,0,0,5.2068817,-489.30756,-507.76085)"><path class="gl1" d="m282.83 170.73-.27-.69-26.14-68.22a6.81 6.81 0 00-2.69-3.24 7 7 0 00-8 .43 7 7 0 00-2.32 3.52l-17.65 54h-71.47l-17.65-54a6.86 6.86 0 00-2.32-3.53 7 7 0 00-8-.43 6.87 6.87 0 00-2.69 3.24L97.44 170l-.26.69a48.54 48.54 0 0016.1 56.1l.09.07.24.17 39.82 29.82 19.7 14.91 12 9.06a8.07 8.07 0 009.76 0l12-9.06 19.7-14.91 40.06-30 .1-.08a48.56 48.56 0 0016.08-56.04z"/><path class="gl2" d="m282.83 170.73-.27-.69a88.3 88.3 0 00-35.15 15.8L190 229.25c19.55 14.79 36.57 27.64 36.57 27.64l40.06-30 .1-.08a48.56 48.56 0 0016.1-56.08z"/><path class="gl3" d="m153.43 256.89 19.7 14.91 12 9.06a8.07 8.07 0 009.76 0l12-9.06 19.7-14.91s-17.04-12.89-36.59-27.64c-19.55 14.75-36.57 27.64-36.57 27.64z"/><path class="gl2" d="M132.58 185.84A88.19 88.19 0 0097.44 170l-.26.69a48.54 48.54 0 0016.1 56.1l.09.07.24.17 39.82 29.82s17-12.85 36.57-27.64z"/></g></svg>
            <span class="relative inline-flex items-center gap-1.5 rounded-full border border-gray-300 bg-white px-4 py-1.5 text-xs font-medium text-gray-600 group-hover:text-gray-950 group-hover:border-gray-400 transition-colors text-center shadow-sm">GitLab CI/CD</span>
          </a>
          <!-- Cloudflare -->
          <a href="https://github.com/withastro/flue/blob/main/docs/deploy-cloudflare.md" target="_blank" rel="noopener noreferrer" class="runner-cell group relative overflow-hidden flex flex-col items-center justify-center gap-4 py-10 px-6 hover:bg-white transition-colors duration-300 sm:border-t sm:border-gray-300 lg:border-t-0">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: radial-gradient(circle at 80% 80%, rgba(244,129,32,0.1) 0%, transparent 60%), radial-gradient(circle at 20% 20%, rgba(250,173,63,0.1) 0%, transparent 60%);"></div>
            <svg class="relative h-10 w-auto grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300" viewBox="0 -8 52 26" fill="none"><path fill="#f48120" d="M34.9,14.1a2.86,2.86,0,0,0-.3-2.6,3.09,3.09,0,0,0-2.1-1.1L15.1,10.2c-.1,0-.2-.1-.3-.1a.19.19,0,0,1,0-.3c.1-.2.2-.3.4-.3l17.5-.2a6.29,6.29,0,0,0,5.1-3.8l1-2.6c0-.1.1-.2,0-.3A11.4,11.4,0,0,0,16.9,1.4a5.46,5.46,0,0,0-3.6-1A5.21,5.21,0,0,0,8.7,5a5.46,5.46,0,0,0,.1,1.8A7.3,7.3,0,0,0,1.7,14.1a4.1,4.1,0,0,0,.1,1.1.32.32,0,0,0,.3.3H34.2c.2,0,.4-.1.4-.3Z"/><path fill="#faad3f" d="M40.4,2.9h-.5c-.1,0-.2.1-.3.2l-.7,2.4a2.86,2.86,0,0,0,.3,2.6,3.09,3.09,0,0,0,2.1,1.1l3.7.2c.1,0,.2.1.3.1a.19.19,0,0,1,0,.3c-.1.2-.2.3-.4.3l-3.8.2a6.29,6.29,0,0,0-5.1,3.8l-.2.9c-.1.1,0,.3.2.3H49.2a.27.27,0,0,0,.3-.3,10.87,10.87,0,0,0,.4-2.6A9.56,9.56,0,0,0,40.4,2.9"/></svg>
            <span class="relative inline-flex items-center gap-1.5 rounded-full border border-gray-300 bg-white px-4 py-1.5 text-xs font-medium text-gray-600 group-hover:text-gray-950 group-hover:border-gray-400 transition-colors text-center shadow-sm">Cloudflare Workers</span>
          </a>
          <!-- Node.js -->
