{
	"name": "@flue/cli",
	"version": "1.0.0-beta.1",
	"type": "module",
	"license": "Apache-2.0",
	"homepage": "https://flueframework.com/",
	"repository": {
		"type": "git",
		"url": "https://github.com/withastro/flue",
		"directory": "packages/cli"
	},
	"bin": {
		"flue": "bin/flue.mjs"
	},
	"exports": {
		"./config": {
			"types": "./dist/config.d.mts",
			"import": "./dist/config.mjs"
		}
	},
	"files": [
		"bin/flue.mjs",
		"dist",
		"docs"
	],
	"engines": {
		"node": ">=22.19.0"
	},
	"scripts": {
		"prebuild": "tsx scripts/generate-blueprint-index.ts",
		"build": "tsdown && mv dist/flue.mjs dist/flue.js",
		"check:types": "tsc --noEmit",
		"pretest": "pnpm run build",
		"test": "node --test test/*.test.mjs && vitest run",
		"test:integration:cloudflare": "vitest run --config vitest.integration.cloudflare.config.ts --no-file-parallelism"
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.39.2",
		"@flue/runtime": "workspace:*",
		"@flue/sdk": "workspace:*",
		"@vercel/detect-agent": "^1.2.3",
		"debug": "^4.4.3",
		"minisearch": "^7.2.0",
		"package-up": "^5.0.0",
		"picocolors": "^1.1.1",
		"ulidx": "^2.4.1",
		"valibot": "^1.0.0",
		"vite": "^8.0.14"
	},
	"devDependencies": {
		"@types/debug": "^4.1.13",
		"tsdown": "^0.22.0",
		"tsx": "^4.19.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	}
}
