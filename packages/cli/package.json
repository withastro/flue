{
	"name": "@flue/cli",
	"version": "0.5.3",
	"type": "module",
	"license": "Apache-2.0",
	"bin": {
		"flue": "bin/flue.mjs"
	},
	"exports": {
		"./config": {
			"types": "./dist/config.d.mts",
			"import": "./dist/config.mjs"
		}
	},
	"files": [
		"bin/flue.mjs",
		"dist"
	],
	"engines": {
		"node": ">=22.18.0"
	},
	"scripts": {
		"prebuild": "tsx scripts/generate-connector-index.ts",
		"build": "tsdown && mv dist/flue.mjs dist/flue.js",
		"check:types": "tsc --noEmit",
		"prepublishOnly": "cp ../../README.md ."
	},
	"dependencies": {
		"@flue/runtime": "workspace:*",
		"@vercel/detect-agent": "^1.2.3",
		"esbuild": "^0.25.0",
		"package-up": "^5.0.0",
		"typescript": "^5.9.2",
		"valibot": "^1.0.0"
	},
	"devDependencies": {
		"tsdown": "^0.20.3",
		"tsx": "^4.19.2",
		"wrangler": "^4.83.0"
	},
	"peerDependencies": {
		"wrangler": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"wrangler": {
			"optional": true
		}
	}
}
