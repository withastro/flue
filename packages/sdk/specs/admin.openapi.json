{
  "openapi": "3.1.0",
  "info": {
    "title": "Flue Admin API",
    "version": "0.5.3",
    "description": "Read-only Flue deployment inspection API."
  },
  "paths": {
    "/agents": {
      "get": {
        "operationId": "adminListAgents",
        "responses": { "200": { "description": "Cursor-paginated list response." } }
      }
    },
    "/agents/{name}/instances": {
      "get": {
        "operationId": "adminListAgentInstances",
        "parameters": [
          { "name": "name", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 1000 } }
        ],
        "responses": { "200": { "description": "Cursor-paginated list response." } }
      }
    },
    "/agents/{name}/instances/{id}/runs": {
      "get": {
        "operationId": "adminListAgentInstanceRuns",
        "parameters": [
          { "name": "name", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["active", "completed", "errored"] } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 1000 } }
        ],
        "responses": { "200": { "description": "Cursor-paginated list response." } }
      }
    },
    "/runs": {
      "get": {
        "operationId": "adminListRuns",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["active", "completed", "errored"] } },
          { "name": "agentName", "in": "query", "schema": { "type": "string" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 1000 } }
        ],
        "responses": { "200": { "description": "Cursor-paginated list response." } }
      }
    },
    "/runs/{runId}": {
      "get": {
        "operationId": "adminGetRun",
        "parameters": [{ "name": "runId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Run record." } }
      }
    }
  }
}
