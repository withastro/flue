{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noForEach": "off"
			},
			"correctness": {
				"noUnusedImports": "warn",
				// Flue source/examples intentionally use bundler-resolved TS imports,
				// including non-standard loader forms such as SKILL.md imports.
				"useImportExtensions": "off"
			},
			"suspicious": {
				// Temporarily disabled while existing repo-wide cleanup is deferred.
				// Re-enable once the broad legacy warning backlog is addressed.
				"noExplicitAny": "off",
				"noConsole": "off",
				"noDebugger": "warn"
			},
			"style": {
				"noInferrableTypes": "off",
				"noUnusedTemplateLiteral": "off",
				"useNodejsImportProtocol": "warn",
				"noNonNullAssertion": "warn"
			}
		}
	},
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"useIgnoreFile": true
	},
	"formatter": {
		"enabled": false
	},
	"files": {
		"includes": ["**", "!apps/www"]
	},
	"overrides": [
		{
			"includes": ["**/tsconfig.json", "**/tsconfig.*.json"],
			"json": {
				"parser": {
					"allowComments": true,
					"allowTrailingCommas": true
				}
			}
		},
		{
			"includes": ["packages/sdk/src/**", "examples/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		}
	]
}
