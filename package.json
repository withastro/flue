{
	"name": "flue",
	"type": "module",
	"private": true,
	"license": "Apache-2.0",
	"packageManager": "pnpm@11.1.1",
	"engines": {
		"node": ">=22",
		"pnpm": ">=11 <12"
	},
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"test": "turbo test",
		"check": "turbo run build check:lint check:types test",
		"check:lint": "biome lint .",
		"check:knip": "knip",
		"check:types": "turbo run check:types",
		"format": "turbo run format:lint format:style",
		"format:lint": "biome check . --write",
		"format:style": "prettier . --cache --write --list-different"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@flue/runtime": "workspace:*",
		"@types/node": "^22.10.10",
		"bgproc": "^0.3.0",
		"knip": "^6.14.2",
		"prettier": "^3.4.2",
		"turbo": "^2.3.3",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"just-bash": "^3.0.1"
	},
	"pnpm": {
		"overrides": {
			"typescript": "6.0.3"
		}
	}
}
